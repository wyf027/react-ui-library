{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "react",
      "react-dom"
    ]
  },
  "include": [
    "docs/**/*",
    ".dumirc.ts",
    ".dumi/app.tsx"
  ],
  "exclude": [
    "node_modules",
    ".dumi/tmp",
    "dist"
  ]
}